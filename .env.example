# AI Operating System — API Keys
# Copy this to .env and fill in your keys

# Active backend (claude | gpt | gemini | colab | ollama)
AI_OS_BACKEND=claude

# Claude (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# GPT (OpenAI) — https://platform.openai.com
OPENAI_API_KEY=sk-...
GPT_MODEL=gpt-4o

# Gemini (Google) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Colab (paste your ngrok URL after running colab_server.py)
COLAB_URL=https://xxxx.ngrok.io
COLAB_API_KEY=

# Ollama (local fallback, no key needed)
OLLAMA_MODEL=phi3:mini
